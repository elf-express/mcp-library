# 複製成 .env(與 docker-compose.mcpjungle.yml 同目錄)後填值。.env 切勿 commit。

# MCPJungle 後端資料庫連線字串。DB 用外部 IP 連(本 stack 不含 Postgres):
#   host 用你 DB 的 IP、port 用該 DB 實際監聽的 port(例 192.168.25.100:15432)。
MCPJUNGLE_DATABASE_URL=postgres://mcpjungle:你的密碼@192.168.25.100:15432/mcpjungle?sslmode=disable

# 選用(有預設值):
# SERVER_MODE=development
# MCPJUNGLE_IMAGE_TAG=latest-stdio
# MCPJUNGLE_HOST_PORT=18800
# MCPJUNGLE_DATA_DIR=/mnt/docker/app/data/mcpjungle
# DOCS_MCP_AUTH_TOKEN=            # dev 留空;硬化時填,並同步 servers/*.json 的 bearer_token
