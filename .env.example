# 一鍵起全部(根 docker-compose.yml)用。複製成 .env 後填值。.env 不進 git。
# 兩處密碼要一致:POSTGRES_PASSWORD 與 MCPJUNGLE_DATABASE_URL 裡的密碼。
POSTGRES_PASSWORD=CHANGE_ME
MCPJUNGLE_DATABASE_URL=postgres://mcpjungle:CHANGE_ME@shared-postgres:5432/mcpjungle?sslmode=disable

# 選用(有預設值,不填即用預設):
# MCPJUNGLE_DATA_DIR=/mnt/docker/app/data/mcpjungle   # filesystem server 讀的 host 目錄
# SERVER_MODE=development
# POSTGRES_HOST_PORT=15432
# MCPJUNGLE_HOST_PORT=18800
# DOCS_MCP_AUTH_TOKEN=

# (legacy:只有在根 compose 加回舊的 standalone include 才需要)
# FC_MCP_AUTH_TOKEN=
# MCP_AUTH_TOKEN=
