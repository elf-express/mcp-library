# 一鍵起 gateway + docs-mcp + registrar 用。複製成 .env 後填值。.env 不進 git。
# DB 用外部 IP 連(本 stack 不含 Postgres、不需 shared-db 網路、不必 docker network create)。
# host 填你 DB 的 IP,port 填該 DB 實際監聽的 port(例:你原本是 192.168.25.100:15432)。
MCPJUNGLE_DATABASE_URL=postgres://mcpjungle:你的密碼@192.168.25.100:15432/mcpjungle?sslmode=disable

# 選用(有預設值,不填即用預設):
# MCPJUNGLE_DATA_DIR=/mnt/docker/app/data/mcpjungle   # filesystem server 讀的 host 目錄
# SERVER_MODE=development
# MCPJUNGLE_HOST_PORT=18800
# DOCS_MCP_AUTH_TOKEN=
