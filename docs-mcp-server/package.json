{
  "name": "@elf-express/docs-mcp-server",
  "version": "1.0.0",
  "description": "Multi-corpus MCP server for searching and reading bundled markdown docs (single server, many corpora)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "docs-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "corpora",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elf-express/mcp-library.git",
    "directory": "docs-mcp-server"
  },
  "homepage": "https://github.com/elf-express/mcp-library/tree/main/docs-mcp-server#readme",
  "bugs": "https://github.com/elf-express/mcp-library/issues",
  "license": "MIT",
  "author": "elf-express",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "documentation",
    "docs",
    "sqlsugar",
    "fcdesigner",
    "claude"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
