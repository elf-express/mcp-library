# 複製成 .env(與 docker-compose.mcpjungle.yml 同目錄)後填值。
# .env 切勿 commit(已列入 .gitignore)。

# MCPJungle 後端資料庫連線字串(把密碼換成你自己的;原本寫死在 compose 的就移到這)
MCPJUNGLE_DATABASE_URL=postgres://mcpjungle:CHANGE_ME@192.168.25.100:15432/mcpjungle?sslmode=disable

# 以下皆可選,有預設值,不填即用預設
# SERVER_MODE=development
# MCPJUNGLE_IMAGE_TAG=latest-stdio
# MCPJUNGLE_HOST_PORT=18800
# MCPJUNGLE_DATA_DIR=/mnt/docker/app/data/mcpjungle
# DOCS_MCP_AUTH_TOKEN=            # dev 留空;硬化時填,並同步 mcpjungle/*.json 的 bearer_token
