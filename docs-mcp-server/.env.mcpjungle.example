# 複製成 .env(與 docker-compose.mcpjungle.yml 同目錄)後填值。.env 切勿 commit(已列入 .gitignore)。

# MCPJungle 後端資料庫連線字串(密碼不落地到 compose / git)。
#  - DB 是 shared-db 網路上的容器 → host 用容器名,例:
#      postgres://mcpjungle:PASS@postgres:5432/mcpjungle?sslmode=disable
#  - DB 是外部主機 / IP → host 用 IP(此時 gateway 其實不需要 shared-db 網路,可拿掉)
MCPJUNGLE_DATABASE_URL=postgres://mcpjungle:CHANGE_ME@postgres:5432/mcpjungle?sslmode=disable

# 網路名(與預設不同才填):
# SHARED_DB_NETWORK=shared-db
# MCPJUNGLE_NETWORK=mcpjungl

# 其餘可選(有預設值,不填即用預設):
# SERVER_MODE=development
# MCPJUNGLE_IMAGE_TAG=latest-stdio
# MCPJUNGLE_HOST_PORT=18800
# MCPJUNGLE_DATA_DIR=/mnt/docker/app/data/mcpjungle
# DOCS_MCP_AUTH_TOKEN=            # dev 留空;硬化時填,並同步 mcpjungle/*.json 的 bearer_token
